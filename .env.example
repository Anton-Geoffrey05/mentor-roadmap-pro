# Clerk (Authentication)
VITE_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxx

# Supabase (Database, Storage, Edge Functions)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_or_publishable_key

# PostHog (Analytics) - optional
VITE_POSTHOG_KEY=phc_xxxxxxxxxxxxxxxxxxxxxxxx
VITE_POSTHOG_HOST=https://app.posthog.com

# Sentry (Error monitoring) - optional
VITE_SENTRY_DSN=https://xxxxxxxxxxxx@sentry.io/xxxxxxx

# ---- Server-side only ----
# These must be set as Supabase Edge Function secrets, NEVER in this file:
#   supabase secrets set GEMINI_API_KEY=... TAVILY_API_KEY=... RESEND_API_KEY=... SUPABASE_SERVICE_ROLE_KEY=...
